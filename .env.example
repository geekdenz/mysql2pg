# Copy this file to .env before running docker compose.
MW_SERVER_BIND_ADDR=0.0.0.0:8080
MW_MYSQL_BIND_ADDR=0.0.0.0:3306
MW_POSTGRES_DRIVER=tokio-postgres
MW_POSTGRES_CONNECTION_STRING=host=postgres port=5432 user=postgres password=postgres dbname=app
MW_TRANSLATOR_REWRITE_LIMIT_COMMA=true
MW_TRANSLATOR_NORMALIZE_MYSQL_BACKTICKS=true
MW_TRANSLATOR_NORMALIZE_BOOLEAN_LITERALS=true
MW_TRANSLATOR_REWRITE_MYSQL_FUNCTIONS=true
MW_TRANSLATOR_REWRITE_JSON_OPERATORS=true
MW_TRANSLATOR_STRIP_MYSQL_TABLE_OPTIONS=true

POSTGRES_DB=app
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432
MIDDLEWARE_PORT=8080
MYSQL_FRONTEND_PORT=3306
RUST_LOG=info
MATOMO_IMAGE_TAG=5.8.0-apache
MATOMO_PORT=8081
MATOMO_DATABASE_HOST=middleware
MATOMO_DATABASE_ADAPTER=MYSQLI
MATOMO_DATABASE_TABLES_PREFIX=matomo_
MATOMO_DATABASE_USERNAME=anyuser
MATOMO_DATABASE_PASSWORD=matomo
MATOMO_DATABASE_DBNAME=app
MATOMO_PHP_MEMORY_LIMIT=512M
